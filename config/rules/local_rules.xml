<group name="local,"> 

 

 

<!-- ── SSH BRUTE FORCE ─────────────────────────────── --> 

<rule id="100001" level="5"> 

<if_sid>5716</if_sid> 

<description>SSH: Login fallido desde $(srcip)</description> 

<group>authentication_failed,ssh,lab,</group> 

</rule> 

 

 

<rule id="100002" level="12" frequency="6" timeframe="90"> 

<if_matched_sid>100001</if_matched_sid> 

<same_field>srcip</same_field> 

<description>SSH BRUTE FORCE: 6+ intentos desde $(srcip)</description> 

<group>brute_force,ssh,lab,attack,</group> 

</rule> 

 

 

<rule id="100003" level="15"> 

<if_matched_sid>100002</if_matched_sid> 

<if_sid>5715</if_sid> 

<same_field>srcip</same_field> 

<description>CRÍTICO: Login exitoso tras brute force desde $(srcip)</description> 

<group>brute_force,ssh,lab,critical,</group> 

</rule> 

 

 

<!-- ── SUDO PRIVILEGE ESCALATION ───────────────────── --> 

<rule id="100010" level="8"> 

<decoded_as>sudo-lab-command</decoded_as> 

<match>USER=root</match> 

<description>Escalada de privilegios via sudo a root</description> 

<group>privilege_escalation,sudo,lab,</group> 

</rule> 

 

 

<rule id="100011" level="14"> 

<decoded_as>sudo-lab-command</decoded_as> 

<match>USER=root</match> 

<match>COMMAND=.*/bin/bash|COMMAND=.*/bin/sh|COMMAND=.*chmod|COMMAND=.*wget|COMMAND=.*curl</match> 

<description>Comando alto riesgo como root via sudo</description> 

<group>privilege_escalation,sudo,lab,high_risk,</group> 

</rule> 

 

 

<!-- ── WEB ATTACKS ─────────────────────────────────── --> 

<rule id="100020" level="10"> 

<decoded_as>nginx-lab-access</decoded_as> 

<match>\.\./ |\.\. %2F|%2E%2E</match> 

<description>WEB: Path traversal desde $(srcip)</description> 

<group>web,path_traversal,lab,attack,</group> 

</rule> 

 

 

<rule id="100021" level="12"> 

<decoded_as>nginx-lab-access</decoded_as> 

<match>union.*select|UNION.*SELECT|DROP.TABLE|INSERT.INTO</match> 

<description>WEB: Posible SQL Injection desde $(srcip)</description> 

<group>web,sqli,lab,attack,</group> 

</rule> 

 

 

<rule id="100022" level="10"> 

<decoded_as>nginx-lab-access</decoded_as> 

<match>%3Cscript%3E|javascript:|onerror=|alert%28</match> 

<description>WEB: Posible XSS desde $(srcip)</description> 

<group>web,xss,lab,attack,</group> 

</rule> 

 

 

<rule id="100023" level="8"> 

<decoded_as>nginx-lab-access</decoded_as> 

<match>\.env|\.git|wp-admin|phpMyAdmin|/admin|/backup|\.bak|\.sql</match> 

<description>WEB: Acceso a ruta sensible desde $(srcip)</description> 

<group>web,recon,lab,</group> 

</rule> 

 

 

<rule id="100024" level="11" frequency="20" timeframe="30"> 

<if_matched_sid>100023</if_matched_sid> 

<same_field>srcip</same_field> 

<description>WEB SCAN: Escaneo masivo desde $(srcip)</description> 

<group>web,recon,lab,scan,</group> 

</rule> 

 

 

<!-- ── MICROSERVICIOS JSON ──────────────────────────── --> 

<rule id="100030" level="5"> 

<field name="service">auth-service</field> 

<field name="event">login_failed</field> 

<description>Microservicio auth: login fallido</description> 

<group>authentication_failed,microservice,lab,</group> 

</rule> 

 

 

<rule id="100031" level="12" frequency="8" timeframe="60"> 

<if_matched_sid>100030</if_matched_sid> 

<same_field>data.ip</same_field> 

<description>BRUTE FORCE en auth-service</description> 

<group>brute_force,microservice,lab,</group> 

</rule> 

 

 

<rule id="100032" level="5"> 

<field name="service">api-gateway</field> 

<field name="event">invalid_token</field> 

<description>API Gateway: token JWT inválido</description> 

<group>api,microservice,lab,</group> 

</rule> 

 

 

<rule id="100035" level="10" frequency="5" timeframe="30"> 

<if_matched_sid>100032</if_matched_sid> 

<same_field>data.ip</same_field> 

<description>API Gateway: múltiples tokens JWT inválidos</description> 

<group>api,microservice,lab,attack,</group> 

</rule> 

 

 

<rule id="100033" level="14"> 

<field name="service">internal-service</field> 

<field name="event">unauthorized_access</field> 

<description>CRÍTICO: Acceso a servicio interno no autorizado</description> 

<group>microservice,lab,critical,</group> 

</rule> 

 

 

<!-- ── THREAT INTELLIGENCE MISP ────────────────────── --> 

<rule id="100050" level="13"> 

<field name="misp_enrichment.misp_matches">\d+</field> 

<description>THREAT INTEL: IOC encontrado en MISP</description> 

<group>threat_intelligence,misp,lab,</group> 

</rule> 

 

 

<rule id="100051" level="15"> 

<if_sid>100050</if_sid> 

<field name="misp_enrichment.threat_level">HIGH</field> 

<description>CRÍTICO: IOC de alta amenaza en MISP</description> 

<group>threat_intelligence,misp,lab,critical,</group> 

</rule> 

 

 

</group> 
